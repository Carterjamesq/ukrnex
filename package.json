{
  "name": "ukrnex",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace @ukrnex/mobile",
    "api": "npm run dev --workspace @ukrnex/api",
    "dev": "concurrently \"npm run api\" \"npm run mobile\"",
    "build:web": "npm run export:web --workspace @ukrnex/mobile",
    "build:netlify": "node ./scripts/netlify-build.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  }
}
